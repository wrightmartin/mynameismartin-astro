---
/*
  CVTimeline Component
  --------------------
  A vertical list of career entries, each showing company, role,
  and date range. Used on the about page as a summary and on the
  full CV page for the complete history.

  Props:
  - showFullCVLink: whether to show the "Full CV" link at the bottom
*/

interface Props {
  showFullCVLink?: boolean;
}

const { showFullCVLink = true } = Astro.props;

/*
  Career entries, most recent first.
  Update these directly when the CV changes.
*/
const entries = [
  {
    company: 'Double True Ltd',
    role: 'Creative Director',
    dates: 'October 2024 – Present',
  },
  {
    company: 'TPXimpact',
    role: 'Lead Design Manager',
    dates: 'September 2021 – October 2024',
  },
  {
    company: 'mySociety',
    role: 'Design Lead',
    dates: 'August 2013 – September 2021',
  },
  {
    company: 'Torchbox',
    role: 'Senior Designer',
    dates: 'June 2012 – August 2013',
  },
  {
    company: 'Shropshire Council',
    role: 'Web Team Leader',
    dates: 'December 2006 – June 2012',
  },
];
---

<div class="cv-timeline">
  <ol class="cv-timeline-list">
    {entries.map((entry) => (
      <li class="cv-timeline-entry">
        <span class="cv-timeline-company">{entry.company}</span>
        <span class="cv-timeline-role">{entry.role}</span>
        <span class="cv-timeline-dates">{entry.dates}</span>
      </li>
    ))}
  </ol>

  {showFullCVLink && (
    <a href="/curriculum-vitae" class="cv-timeline-link">Full CV →</a>
  )}
</div>

<style>
  /* ==========================================================================
     CV Timeline
     A clean vertical list of career entries with a subtle left border.
     ========================================================================== */

  .cv-timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--colour-border);
    padding-left: var(--space-lg);
  }

  .cv-timeline-entry {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-lg);
    position: relative;
  }

  .cv-timeline-entry:last-child {
    padding-bottom: 0;
  }

  /* Small dot on the timeline line */
  .cv-timeline-entry::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-lg) - 5px);
    top: 0.35em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--colour-text);
  }

  .cv-timeline-company {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1.3;
    color: var(--colour-text);
  }

  .cv-timeline-role {
    font-size: var(--text-body);
    color: var(--colour-text-light);
    margin-top: var(--space-2xs);
  }

  .cv-timeline-dates {
    font-family: var(--font-heading);
    font-size: var(--text-small);
    color: var(--colour-text-light);
    margin-top: var(--space-2xs);
  }

  .cv-timeline-link {
    display: inline-block;
    margin-top: var(--space-lg);
    font-family: var(--font-heading);
    font-size: var(--text-body);
  }
</style>
