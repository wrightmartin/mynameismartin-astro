---
/*
  CVTimeline Component
  --------------------
  A vertical list of career entries, each showing company, role,
  and date range. Used on the about page as a summary and on the
  full CV page for the complete history.

  Props:
  - showFullCVLink: whether to show the "Full CV" link at the bottom
*/

interface Props {
  showFullCVLink?: boolean;
  showDescriptions?: boolean;
}

const { showFullCVLink = true, showDescriptions = false } = Astro.props;

/*
  Career entries, most recent first.
  Update these directly when the CV changes.
*/
const entries = [
  {
    company: 'Double True Ltd',
    role: 'Founder and Design Lead',
    dates: 'October 2024 – Present',
    description: 'Independent design practice for regulated problem spaces. Leads end-to-end engagements from discovery through early delivery, combining service design and product thinking. Holds full commercial responsibility including scoping, pitching, budgeting, and senior stakeholder management.',
  },
  {
    company: 'TPXimpact',
    role: 'Lead Design Manager',
    dates: 'September 2021 – October 2024',
    description: 'Senior design leader in public-sector consultancy. Built cross-functional design community of practice. Scaled design leadership through organizational change, growing practice from ~35 to 110 designers post-merger. Held design resourcing responsibility across multiple engagements.',
  },
  {
    company: 'mySociety',
    role: 'Design Lead',
    dates: 'August 2013 – September 2021',
    description: 'Led product design for civic technology platforms including TheyWorkForYou, FixMyStreet, and WhatDoTheyKnow. Shared responsibility for product direction, prioritization, and delivery. Set standards for usability, accessibility, and content clarity. Led organizational rebrand rollout.',
  },
  {
    company: 'Torchbox',
    role: 'Senior Designer',
    dates: 'June 2012 – August 2013',
    description: 'Delivered large-scale digital products for charities and academic institutions. Design lead on University of Oxford website (Higher Education Website of the Year, 2015 & 2016).',
  },
  {
    company: 'Shropshire Council',
    role: 'Web Team Leader',
    dates: 'December 2006 – June 2012',
    description: 'Established design as core discipline in local government. Led design for all public-facing services, managing multidisciplinary team through organizational consolidation and platform migration.',
  },
];
---

<div class="cv-timeline">
  <ol class="cv-timeline-list">
    {entries.map((entry) => (
      <li class="cv-timeline-entry">
        <span class="cv-timeline-company">{entry.company}</span>
        <span class="cv-timeline-role">{entry.role}</span>
        <span class="cv-timeline-dates">{entry.dates}</span>
        {showDescriptions && entry.description && (
          <p class="cv-timeline-description">{entry.description}</p>
        )}
      </li>
    ))}
  </ol>

  {showFullCVLink && (
    <a href="/curriculum-vitae" class="cv-timeline-link">Full CV →</a>
  )}
</div>

<style>
  /* ==========================================================================
     CV Timeline
     A clean vertical list of career entries with a subtle left border.
     ========================================================================== */

  .cv-timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--colour-border);
    padding-left: var(--space-lg);
  }

  .cv-timeline-entry {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-lg);
    position: relative;
  }

  .cv-timeline-entry:last-child {
    padding-bottom: 0;
  }

  /* Small dot on the timeline line */
  .cv-timeline-entry::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-lg) - 5px);
    top: 0.35em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--colour-text);
  }

  .cv-timeline-company {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1.3;
    color: var(--colour-text);
  }

  .cv-timeline-role {
    font-size: var(--text-body);
    color: var(--colour-text-light);
    margin-top: var(--space-2xs);
  }

  .cv-timeline-dates {
    font-family: var(--font-heading);
    font-size: var(--text-small);
    color: var(--colour-text-light);
    margin-top: var(--space-2xs);
  }

  .cv-timeline-description {
    margin-top: var(--space-sm);
    color: var(--colour-text-light);
    line-height: 1.6;
    max-width: 55ch;
  }

  .cv-timeline-link {
    display: inline-block;
    margin-top: var(--space-lg);
    font-family: var(--font-heading);
    font-size: var(--text-body);
  }
</style>
