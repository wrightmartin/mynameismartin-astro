---
/*
  Hero Component
  --------------
  The large introductory section at the top of the homepage.
  Displays the main heading, subheading, three service descriptions,
  availability notice, and a placeholder for a hero image.
*/

import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.jpg';
---

<section class="hero full-bleed bg-white">
  <div class="full-bleed-inner">
    <div class="grid-4">
      <Image src={heroImage} alt="Martin Wright" class="hero-image" width={800} quality={80} format="webp" loading="eager" fetchpriority="high" />
      <div class="span-3">
      <!-- Main introduction -->
      <div class="hero-content">
        <h1 class="hero-heading">
          <span class="scaled-line">My name is <span class="marker marker--a">Martin</span>,</span>
          <span class="scaled-line">human centred</span>
          <span class="scaled-line">designer for hire</span>
        </h1>
        <p class="hero-subheading">I design complex digital products and services where clarity, trust, and delivery matter.</p>
      </div>


      <!-- Three service descriptions -->
      <div class="hero-services">

        <div class="hero-service">
          <h2 class="hero-service-title">Human centred design</h2>
          <p>I work directly with the people affected by the things I design. In the room, building, testing, and learning alongside them. I know when to listen and when to act.</p>
        </div>

        <div class="hero-service">
          <h2 class="hero-service-title">Design leadership</h2>
          <p>Good design needs time to think, permission to challenge, and clear direction. I care for the people, hold the line on what matters, and trust good teams to do good work.</p>
        </div>

        <div class="hero-service">
          <h2 class="hero-service-title">UX &amp; digital strategy</h2>
          <p>I help organisations figure out what to build and how to build it. That means navigating power, policy, and legacy systems to make sure the right thing gets built.</p>
        </div>

      </div>

      <!-- Availability notice -->
      <p class="hero-availability">
        Next availability from mid 2026.
        <a href="/get-in-touch">Get in touch</a>
      </p>
      </div>
    </div>
  </div>
</section>
