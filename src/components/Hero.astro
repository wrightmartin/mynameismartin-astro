---
/*
  Hero Component
  --------------
  The large introductory section at the top of the homepage.
  Displays the main heading, subheading, three service descriptions,
  availability notice, and a placeholder for a hero image.
*/
---

<section class="hero">

  <!-- Main introduction -->
  <div class="hero-content">
    <h1 class="hero-heading">My name is Martin, human centred designer for&nbsp;hire</h1>
    <p class="hero-subheading">I design complex digital products and services where clarity, trust, and delivery matter.</p>
  </div>

  <img src="/images/hero.jpg" alt="Martin Wright" class="hero-image" />

  <!-- Three service descriptions -->
  <div class="hero-services">

    <div class="hero-service">
      <h2 class="hero-service-title">Human centred design</h2>
      <p>I design products and services to solve real problems with the people most affected, through understanding, collaboration, and inclusion.</p>
    </div>

    <div class="hero-service">
      <h2 class="hero-service-title">Design leadership</h2>
      <p>I've led and supported teams of all sizes across a wide range of sectors, helping people do important, impactful work under real constraints.</p>
    </div>

    <div class="hero-service">
      <h2 class="hero-service-title">UX &amp; digital strategy</h2>
      <p>I help teams and organisations use digital systems to overcome complexity, reach the right audiences, and deliver meaningful outcomes.</p>
    </div>

  </div>

  <!-- Availability notice -->
  <p class="hero-availability">
    Next availability from early 2026.
    <a href="/get-in-touch">Get in touch</a>
  </p>

</section>

<style>
  /* ==========================================================================
     Hero
     Large introductory section with heading, services grid, and image space.
     ========================================================================== */

  .hero {
    padding-block: var(--space-2xl) var(--space-3xl);
  }


  /* --- Main heading and subheading ---
     The heading is large (uses the global H1 size from typography.css).
     The subheading is a slightly larger body text in the lighter colour.
     ---------------------------------------------------------------------- */

  .hero-content {
    max-width: 800px;
    margin-bottom: var(--space-xl);
  }

  .hero-heading {
    margin-bottom: var(--space-md);
  }

  .hero-subheading {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--colour-text-light);
    max-width: 55ch;
  }


  /* --- Hero image ---
     ---------------------------------------------------------------------- */

  .hero-image {
    width: 100%;
    border-radius: 4px;
    margin-bottom: var(--space-2xl);
  }


  /* --- Service descriptions ---
     Three columns on desktop, stacking to one column on mobile.
     Uses the heading font for the service titles.
     ---------------------------------------------------------------------- */

  .hero-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 768px) {
    .hero-services {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xl);
    }
  }

  .hero-service-title {
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }

  .hero-service p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--colour-text-light);
    max-width: 45ch;
  }


  /* --- Availability notice ---
     A simple line of text with a link to the contact page.
     ---------------------------------------------------------------------- */

  .hero-availability {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    color: var(--colour-text);
  }

  .hero-availability a {
    color: var(--colour-text);
  }
</style>
