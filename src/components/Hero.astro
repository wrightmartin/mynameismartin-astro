---
/*
  Hero Component
  --------------
  The large introductory section at the top of the homepage.
  Displays the main heading, subheading, three service descriptions,
  availability notice, and a placeholder for a hero image.
*/
---

<section class="hero full-bleed bg-white">
  <div class="full-bleed-inner">
    <div class="grid-4">
      <img src="/images/hero.jpg" alt="Martin Wright" class="hero-image" />
      <div class="span-3">
      <!-- Main introduction -->
      <div class="hero-content">
        <h1 class="hero-heading scaled-text" data-scaled-text>
          <span class="scaled-line">My name is <span class="marker marker--a">Martin</span>,</span>
          <span class="scaled-line">human centred</span>
          <span class="scaled-line">designer for hire</span>
        </h1>
        <p class="hero-subheading">I design complex digital products and services where clarity, trust, and delivery matter.</p>
      </div>


      <!-- Three service descriptions -->
      <div class="hero-services">

        <div class="hero-service">
          <h2 class="hero-service-title">Human centred design</h2>
          <p>I design products and services to solve real problems with the people most affected, through understanding, collaboration, and inclusion.</p>
        </div>

        <div class="hero-service">
          <h2 class="hero-service-title">Design leadership</h2>
          <p>I've led and supported teams of all sizes across a wide range of sectors, helping people do important, impactful work under real constraints.</p>
        </div>

        <div class="hero-service">
          <h2 class="hero-service-title">UX &amp; digital strategy</h2>
          <p>I help teams and organisations use digital systems to overcome complexity, reach the right audiences, and deliver meaningful outcomes.</p>
        </div>

      </div>

      <!-- Availability notice -->
      <p class="hero-availability">
        Next availability from mid 2026.
        <a href="/get-in-touch">Get in touch</a>
      </p>
      </div>
    </div>
  </div>
</section>
