---
/*
  Header Component
  ----------------
  Site header with logo on the left and navigation on the right.
  Becomes sticky on scroll with a subtle frosted background.
  Mobile navigation uses a checkbox hack — no JS framework needed.

  Current page is highlighted by comparing Astro.url.pathname
  against each link's href.
*/

/* Get the current page path to mark the active nav link */
const currentPath = Astro.url.pathname;

/* Navigation links — these match the existing site exactly */
const navLinks = [
  { label: 'Work',       href: '/work' },
  { label: 'Blog',       href: '/blog' },
  { label: 'About',      href: '/about' },
  { label: 'Contact me', href: '/get-in-touch' },
];

/**
 * Check if a nav link is the "current" page.
 * We match on the starting segment so /work also highlights on /work/some-project.
 */
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">

    <!-- Logo -->
    <a href="/" class="site-header-logo" aria-label="Home — mynameismartin">
      <img src="/images/mnim.png.webp" alt="mynameismartin" />
    </a>

    <!--
      Mobile menu toggle
      Uses a hidden checkbox so the menu opens/closes with pure CSS.
      The <label> acts as the hamburger button.
    -->
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle-checkbox"
      aria-hidden="true"
    />
    <label for="nav-toggle" class="nav-toggle-button" aria-label="Toggle navigation menu">
      <span class="nav-toggle-icon"></span>
    </label>

    <!-- Navigation -->
    <nav class="site-nav" aria-label="Main navigation">
      <ul class="site-nav-list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['site-nav-link', { 'is-active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>

<style>
  /* ==========================================================================
     Site Header
     Sticky header with frosted glass effect on scroll.
     ========================================================================== */

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease;
  }

  /*
    When the page has scrolled, a small script on the <body> adds
    the [data-scrolled] attribute to <html>. This triggers the
    frosted background so the header doesn't obscure content beneath it.
  */
  :global(html[data-scrolled]) .site-header {
    background-color: rgba(245, 240, 235, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 1.6vw var(--gutter);
  }

  @media (max-width: 768px) {
    .site-header-inner {
      padding: 1rem var(--gutter-mobile);
    }
  }


  /* --- Logo ---
     Matches the existing site's logo sizing.
     80px tall on desktop, 30px on mobile.
     ------------------------------------------------------------------- */

  .site-header-logo {
    display: block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-header-logo img {
    height: 80px;
    width: auto;
  }

  @media (max-width: 768px) {
    .site-header-logo img {
      height: 30px;
    }
  }


  /* --- Desktop Navigation ---
     Clean sans-serif links with no underline, matching the existing site.
     Active page gets a subtle underline indicator.
     ------------------------------------------------------------------- */

  .site-nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 400;
    color: var(--colour-text);
    text-decoration: none;
    padding-block: 0.25rem;
    position: relative;
    transition: color 0.2s ease;
  }

  .site-nav-link:hover {
    color: var(--colour-text-light);
  }

  /* Active page indicator — a small underline below the link */
  .site-nav-link.is-active {
    font-weight: 600;
  }

  .site-nav-link.is-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--colour-text);
    border-radius: 1px;
  }


  /* --- Mobile Menu Toggle ---
     The checkbox is visually hidden. The <label> draws a hamburger icon
     using a pseudo-element sandwich. When checked, the nav slides open.
     ------------------------------------------------------------------- */

  .nav-toggle-checkbox {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .nav-toggle-button {
    display: none;         /* hidden on desktop */
    cursor: pointer;
    width: 32px;
    height: 24px;
    position: relative;
    z-index: 110;
  }

  /*
    The hamburger icon: three horizontal lines.
    The middle line is the .nav-toggle-icon element itself,
    and the top/bottom lines are its ::before and ::after.
  */
  .nav-toggle-icon,
  .nav-toggle-icon::before,
  .nav-toggle-icon::after {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--colour-text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav-toggle-icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }

  .nav-toggle-icon::before {
    content: '';
    position: absolute;
    top: -8px;
  }

  .nav-toggle-icon::after {
    content: '';
    position: absolute;
    bottom: -8px;
  }

  /*
    When the checkbox is checked, morph the hamburger into an X.
    The middle line fades out, and the top/bottom rotate to cross.
  */
  .nav-toggle-checkbox:checked ~ .nav-toggle-button .nav-toggle-icon {
    background-color: transparent;
  }

  .nav-toggle-checkbox:checked ~ .nav-toggle-button .nav-toggle-icon::before {
    top: 0;
    transform: rotate(45deg);
  }

  .nav-toggle-checkbox:checked ~ .nav-toggle-button .nav-toggle-icon::after {
    bottom: 0;
    transform: rotate(-45deg);
  }


  /* --- Mobile Layout ---
     Below 768px the hamburger appears and the nav becomes a full-screen overlay.
     ------------------------------------------------------------------- */

  @media (max-width: 768px) {
    .nav-toggle-button {
      display: block;
    }

    .site-nav {
      position: fixed;
      inset: 0;
      z-index: 100;
      background-color: var(--colour-background);
      display: flex;
      align-items: center;
      justify-content: center;

      /* Hidden by default — slides in from right */
      opacity: 0;
      visibility: hidden;
      transform: translateX(100%);
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    }

    /* When the checkbox is checked, show the nav overlay */
    .nav-toggle-checkbox:checked ~ .site-nav {
      opacity: 1;
      visibility: visible;
      transform: translateX(0);
    }

    .site-nav-list {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }

    .site-nav-link {
      font-size: 1.5rem;
    }
  }
</style>

<!--
  Scroll detection
  A tiny inline script that toggles a data attribute on <html>
  when the user scrolls past the first few pixels. This lets CSS
  add the frosted background to the sticky header without any framework.
-->
<script>
  function updateScrollState() {
    if (window.scrollY > 10) {
      document.documentElement.setAttribute('data-scrolled', '');
    } else {
      document.documentElement.removeAttribute('data-scrolled');
    }
  }

  /* Run on load and on scroll */
  updateScrollState();
  window.addEventListener('scroll', updateScrollState, { passive: true });

  /*
    Re-attach after Astro View Transitions swap in a new page,
    since the scroll position resets.
  */
  document.addEventListener('astro:after-swap', updateScrollState);
</script>
