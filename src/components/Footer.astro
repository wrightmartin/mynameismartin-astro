---
/*
  Footer Component
  ----------------
  Site footer with logo, navigation links, and RSS subscription link.
  Clean and generously spaced, matching the existing site's appearance.
*/
---

<footer class="site-footer inverted">
  <div class="site-footer-inner">

    <!-- Logo -->
    <div class="site-footer-logo">
      <a href="/" aria-label="Home — mynameismartin">
        <img src="/images/mnim.png.webp" alt="mynameismartin" />
      </a>
    </div>

    <!-- Navigation — mirrors the header links -->
    <nav class="site-footer-nav" aria-label="Footer navigation">
      <ul class="site-footer-nav-list">
        <li><a href="/work">Work</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/get-in-touch">Contact me</a></li>
      </ul>
    </nav>

    <!-- RSS feed link -->
    <div class="site-footer-rss">
      <a href="/blog/rss.xml" class="site-footer-rss-link">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
        Subscribe to my RSS feed
      </a>
    </div>

  </div>
</footer>
