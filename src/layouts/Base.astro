---
/*
  Base Layout
  -----------
  The HTML shell shared by every page on the site.
  Handles <head> meta, Google Fonts loading, global CSS imports,
  Open Graph / Twitter meta, canonical URL, and Astro View Transitions.
*/


import '../styles/global.css';
import '../styles/typography.css';
import '../styles/layout.css';
import '../styles/components.css';
import '../styles/pages.css';
import '../styles/utilities.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: Date;
  author?: string;
}

const siteName = 'mynameismartin';
const defaultDescription = 'I design complex digital products and services where clarity, trust, and delivery matter.';
const defaultOgImage = '/images/mnim.png.webp';

const {
  title,
  description = defaultDescription,
  ogImage = defaultOgImage,
  ogType = 'website',
  publishedTime,
  author,
} = Astro.props;

const pageTitle = title ? `${title} — ${siteName}` : siteName;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Page title and description -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS feed discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Blog RSS Feed"
      href="/blog/rss.xml"
    />

    <!--
      Google Fonts
      Albert Sans — headings
      PT Serif — body text
      Preconnect first for faster loading, then load the stylesheet.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;600;700;800&family=PT+Serif:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
      <script>
      function applyScaledText(root = document) {
        const wraps = root.querySelectorAll("[data-scaled-text]");

        wraps.forEach((wrap) => {
          const lines = Array.from(wrap.querySelectorAll(".scaled-line"));
          if (!lines.length) return;

          // Use the wrapping element’s width as the available width
          const containerWidth = wrap.clientWidth;
          if (!containerWidth) return;

          // Ensure measurements happen with the actual font loaded
          const baseSize = parseFloat(getComputedStyle(wrap).fontSize) || 16;

          // Reset line sizes to the base so we can measure their natural widths
          lines.forEach((line) => (line.style.fontSize = `${baseSize}px`));

          const widths = lines.map((line) => line.getBoundingClientRect().width);
          const longest = Math.max(...widths);
          if (!longest) return;

          // Stage 1: compute the max “group” font-size so the longest line fits
          const groupScale = containerWidth / longest;

          // Clamp the overall scale so it doesn’t go silly on tiny/huge screens
          const MIN_GROUP_SCALE = 0.85;
          const MAX_GROUP_SCALE = 1.6;
          const clampedGroupScale = Math.max(MIN_GROUP_SCALE, Math.min(MAX_GROUP_SCALE, groupScale));

          const groupBase = baseSize * clampedGroupScale;

          // Stage 2: scale each line’s font-size so it fits the container width
          // (shorter lines become larger; still only font-size changes)
          const MIN_LINE_SCALE = 0.9;
          const MAX_LINE_SCALE = 2.2;

          lines.forEach((line, i) => {
            const w = widths[i];
            if (!w) return;

            let lineScale = containerWidth / w;
            lineScale = Math.max(MIN_LINE_SCALE, Math.min(MAX_LINE_SCALE, lineScale));

            // Important: anchor the per-line scaling to the same group base
            line.style.fontSize = `${groupBase * (lineScale / clampedGroupScale)}px`;
          });
        });
      }

      async function runScaledText() {
        // wait for webfonts so widths are accurate
        if (document.fonts?.ready) {
          try { await document.fonts.ready; } catch {}
        }
        applyScaledText(document);
      }

      window.addEventListener("load", runScaledText);

      // Resize (throttled)
      let rt;
      window.addEventListener("resize", () => {
        clearTimeout(rt);
        rt = setTimeout(runScaledText, 100);
      });

      // Astro view transitions
      document.addEventListener("astro:after-swap", runScaledText);
    </script>
    
    <!-- 100% privacy-first analytics -->
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>

  </body>
</html>
