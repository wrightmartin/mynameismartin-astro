---
/*
  Post Layout
  -----------
  Layout for individual blog posts.
  Displays the post title, date, and rendered markdown content.
*/

import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  date: Date;
  category: string;
}

const { title, date, category } = Astro.props;

/* Format the date as a readable string, e.g. "25 February 2026" */
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base title={title}>
  <Header />

  <main class="page-container">
    <article class="page-section">
      <header>
        <p class="post-card-category">{category}</p>
        <h1>{title}</h1>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</Base>
