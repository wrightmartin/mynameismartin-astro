---
/*
  Success Page
  ------------
  Shown after a successful contact form submission.
*/

import Page from '../layouts/Page.astro';
---

<Page title="Message sent" description="Your message has been sent successfully.">

  <section class="page-section not-found">
    <h1>Thanks for your message</h1>
    <p>I'll get back to you within a day or two.</p>
    <ul class="not-found-links">
      <li><a href="/">Back to homepage</a></li>
    </ul>
  </section>

</Page>
