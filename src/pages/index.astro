---
/*
  Home Page
  ---------
  The landing page. Composed of distinct sections:
  1. Hero — heading, services, availability
  2. Featured projects — top 3 work items marked as featured
  3. Client logos — organisations worked with
  4. Blog — 3 most recent posts
  5. About excerpt — short bio with link to full about page
*/

import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import ClientLogos from '../components/ClientLogos.astro';
import { getCollection } from 'astro:content';

/* Fetch featured projects, sorted by order, limited to 3 */
const allProjects = await getCollection('work');
const featuredProjects = allProjects
  .filter((project) => project.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

/* Fetch the 3 most recent blog posts */
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Page>

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Featured projects -->
  <section class="page-section">
    <h2 class="home-section-heading">My work</h2>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <ProjectCard
          title={project.data.cardTitle || project.data.title}
          slug={project.data.slug}
          subtitle={project.data.subtitle}
          thumbnail={project.data.thumbnail}
        />
      ))}
    </div>
  </section>

  <!-- 3. Client logos -->
  <ClientLogos />

  <!-- 4. Blog -->
  <section class="page-section">
    <h2 class="home-section-heading">Blog</h2>
    <div class="home-posts grid-3 align-items-start">
      {recentPosts.map((post) => (
        <PostCard
          title={post.data.title}
          slug={post.data.slug}
          date={post.data.date}
          excerpt={post.data.excerpt}
          category={post.data.category}
        />
      ))}
    </div>
  </section>

  <!-- 5. About excerpt -->
  <section class="page-section home-about full-bleed bg-white">
    <div class="full-bleed-inner">
      <div class="grid-3">
        <div>
          <h2 class="h3">About</h2>
        </div>
        <div class="span-2">
          <p>I'm a designer with twenty years' extensive and celebrated experience designing websites and services for clients including central and local government, healthcare, charity, and the private sector.</p>
          <a href="/about" class="home-about-link">More about me…</a>
        </div>
      </div>
    </div>
  </section>

</Page>
