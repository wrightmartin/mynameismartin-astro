---
/*
  Curriculum Vitae Page
  ---------------------
  Full detailed CV with profile summary, career history with descriptions,
  education, and a note about requesting a tailored version.
*/

import Page from '../layouts/Page.astro';
import CVTimeline from '../components/CVTimeline.astro';
---

<Page title="Curriculum Vitae — Martin Wright">

  <section class="page-section">
    <div class="page-header">
      <h1>Curriculum Vitae</h1>
      <p>Twenty years of designing digital products and services that make a difference.</p>
    </div>
  </section>

  <!-- Profile summary -->
  <section class="page-section">
    <h2>Profile</h2>
    <div class="prose cv-prose">
      <p>Design leader specialising in complex digital products and services. Extensive experience building experience design capability in consultancy and public-sector settings. Has grown and supported teams through rapid change, overseen design quality across multiple engagements, and partnered with delivery leadership to ship real-world services.</p>
      <p>Remains hands-on on complex, high-risk problems involving policy, regulation, data, and multi-stakeholder delivery.</p>
    </div>
  </section>

  <!-- Career history -->
  <section class="page-section">
    <h2>Experience</h2>
    <div class="cv-timeline-wrapper">
      <CVTimeline showFullCVLink={false} showDescriptions={true} />
    </div>
  </section>

  <!-- Education -->
  <section class="page-section">
    <h2>Education</h2>
    <div class="prose cv-prose">
      <p><strong>2:1 BSc Computer Science</strong> — University of Wales, Aberystwyth</p>
    </div>
  </section>

  <!-- Note -->
  <section class="page-section">
    <div class="prose cv-prose">
      <p>A more detailed, role-specific CV is available on request.</p>
    </div>
  </section>

</Page>

<style>
  /* Keep CV prose and timeline at a comfortable reading width */
  .cv-prose {
    max-width: var(--content-width);
    margin-top: var(--space-md);
  }

  .cv-timeline-wrapper {
    max-width: var(--content-width);
    margin-top: var(--space-lg);
  }
</style>
