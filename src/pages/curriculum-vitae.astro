---
/*
  Curriculum Vitae Page
  ---------------------
  Full detailed CV with profile summary, career history with descriptions,
  education, and a note about requesting a tailored version.
*/

import Page from '../layouts/Page.astro';
import CVTimeline from '../components/CVTimeline.astro';
---

<Page title="Curriculum Vitae" description="Career history and experience of designer Martin Wright.">

  <section class="page-section">
    <div class="page-header">
      <h1>Martin Wright</h1>
    </div>
 
    <div class="prose cv-prose">
      <p>Design leader with deep experience building and leading experience design capability in consultancy and public-sector contexts. I've grown and supported teams through periods of rapid change, overseen design quality and resourcing across multiple concurrent engagements, and partnered closely with delivery and commercial leadership to ship services that work in the real world.</p>
      <p>Alongside practice leadership, I remain hands-on where it matters — particularly on complex, high-risk problems involving policy, regulation, data, and multi-stakeholder delivery.</p>
      <!-- Decorative section divider -->
      <hr class="decorative-hr mt-6" />
    
    <h2>Experience</h2>

    <div class="cv-role">
      <h3>Double True Ltd · Founder and Design Lead</h3>
      <p class="cv-dates">October 2024 – Present</p>
      <p>Independent design practice delivering hands-on product and service design for complex, regulated problem spaces.</p>
      <ul>
        <li>Lead end-to-end engagements from discovery through early delivery, combining service design, product thinking, and practical execution</li>
        <li>Hold full commercial responsibility including scoping, pitching, budgeting, and senior stakeholder management</li>
        <li>Work directly with engineers, researchers, and delivery leads to ship credible, production-oriented outcomes under real-world constraints</li>
      </ul>
      <div class="cv-selected-work">
        <h4>Selected work</h4>
        <p><strong>ecosyste.ms</strong> — A platform-wide brand and design system for an open-source sustainability initiative, unifying more than a dozen data-heavy services under a single visual and interaction framework.</p>
      </div>
    </div>

    <div class="cv-role">
      <h3>TPXimpact · Lead Design Manager</h3>
      <p class="cv-dates">September 2021 – October 2024</p>
      <p>Senior design leader within a large public-sector consultancy.</p>
      <ul>
        <li>Built and sustained a cross-functional design community of practice, creating shared standards, peer support, and continuity beyond individual projects</li>
        <li>Scaled design leadership capability through significant organisational change, growing the design practice from ~35 to 110 designers post-merger</li>
        <li>Held responsibility for design resourcing across multiple engagements, balancing utilisation, client demand, and individual development</li>
        <li>Acted as senior design authority across concurrent programmes, accountable for design quality and outcomes</li>
        <li>Played a leading role in business development and bids, owning design strategy and pitching design-led approaches to central government and local authorities</li>
        <li>Embedded product leadership</li>
      </ul>
      <div class="cv-selected-work">
        <p><strong>Central Government Funding Service (MHCLG)</strong> — Design lead on a three-year programme bringing a national funding service to Beta. Led service and product design for fund onboarding, defined a long-term product vision in a politically sensitive policy area, and reduced assessor preparation time by 90% and fund onboarding time by 75%.</p>
      </div>
    </div>

    <div class="cv-role">
      <h3>mySociety · Design Lead</h3>
      <p class="cv-dates">August 2013 – September 2021</p>
      <ul>
        <li>Led product design for long-running civic technology platforms used by millions, including TheyWorkForYou, FixMyStreet, and WhatDoTheyKnow</li>
        <li>Shared responsibility for product direction, prioritisation, and delivery</li>
        <li>Set standards for usability, accessibility, and content clarity across products handling sensitive civic data</li>
        <li>Led a full organisational rebrand and rollout across the product suite</li>
      </ul>
    </div>

    <div class="cv-role">
      <h3>Torchbox · Senior Designer</h3>
      <p class="cv-dates">June 2012 – August 2013</p>
      <ul>
        <li>Delivered large-scale digital products for charities and academic institutions</li>
        <li>Design lead on the University of Oxford website (Higher Education Website of the Year, 2015 & 2016)</li>
      </ul>
    </div>

    <div class="cv-role">
      <h3>Shropshire Council · Web Team Leader</h3>
      <p class="cv-dates">December 2006 – June 2012</p>
      <ul>
        <li>Established design as a core discipline when design capability was rare in local government</li>
        <li>Led design for all public-facing services, managing a multidisciplinary team through organisational consolidation and platform migration</li>
      </ul>
    </div>
    <!-- Decorative section divider -->
    <hr class="decorative-hr mt-6" />
    <h2>Education</h2>
    <div class="prose cv-prose">
      <p><strong>2:1 BSc Computer Science</strong> · University of Wales, Aberystwyth</p>
    </div>
  </div>
  </section>

  <!-- Note -->
  <section class="page-section">
    <div class="prose cv-prose">
      <p>A more detailed, role-specific CV is available on request.</p>
    </div>
  </section>

</Page>
