---
/*
  404 Page
  --------
  Custom not-found page with a friendly tone and helpful links.
*/

import Page from '../layouts/Page.astro';
---

<Page title="Page not found">

  <section class="page-section not-found">
    <h1>Sorry</h1>
    <p>The page you're looking for doesn't exist — it might have been moved, renamed, or it never existed in the first place.</p>
    <p>Here are some places you <em>can</em> go:</p>
    <ul class="not-found-links">
      <li><a href="/">Home</a></li>
      <li><a href="/work">Work</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/get-in-touch">Get in touch</a></li>
    </ul>
  </section>

</Page>
