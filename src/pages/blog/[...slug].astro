---
/*
  Individual Blog Post
  --------------------
  Dynamic route that renders a single blog post or weeknote.
  Displays the date, title, category label (for weeknotes),
  rendered markdown content, and an author bio at the bottom.
*/

import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  /* Sort by date ascending so index - 1 = older, index + 1 = newer */
  const sorted = posts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

  return sorted.map((post, index) => ({
    params: { slug: post.data.slug },
    props: {
      post,
      prevPost: index > 0 ? sorted[index - 1] : null,
      nextPost: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

/* Format the date as a readable string, e.g. "10 January 2025" */
const formattedDate = post.data.date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const isWeeknote = post.data.category === 'weeknote';
---

<Base
  title={post.data.title}
  description={post.data.excerpt}
  ogType="article"
  ogImage={post.data.thumbnail}
  publishedTime={post.data.date}
  author="Martin Wright"
>
  <Header />

  <main class="page-container">
    <article class="blog-post">

      <!-- Post header: date, category label, title -->
      <header class="blog-post-header page-section">
        <time class="blog-post-date" datetime={post.data.date.toISOString()}>
          {formattedDate}
        </time>
        {isWeeknote && (
          <span class="blog-post-category">Weeknote</span>
        )}
        <h1>{post.data.title}</h1>
      </header>

      <!-- Markdown content -->
      <div class="blog-post-body page-section">
        <div class="prose">
          <Content />
        </div>
      </div>

    </article>

    <!-- Previous / Next post navigation -->
    {(prevPost || nextPost) && (
      <nav class="case-study-nav page-section" aria-label="More posts">

        {prevPost ? (
          <a href={`/blog/${prevPost.data.slug}`} class="case-study-nav-link case-study-nav-prev">
            <span class="case-study-nav-direction">Previous post</span>
            <span class="case-study-nav-title">{prevPost.data.title}</span>
          </a>
        ) : (
          <span></span>
        )}

        {nextPost ? (
          <a href={`/blog/${nextPost.data.slug}`} class="case-study-nav-link case-study-nav-next">
            <span class="case-study-nav-direction">Next post</span>
            <span class="case-study-nav-title">{nextPost.data.title}</span>
          </a>
        ) : (
          <span></span>
        )}

      </nav>
    )}

  </main>

  <Footer />

  <!--
    Sidenote footnote collector.
    On small screens, sidenotes are hidden inline and shown as numbered
    footnotes at the bottom of the post. This script clones each sidenote
    into an ordered list appended to .prose. CSS handles show/hide.
  -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const prose = document.querySelector('.blog-post-body .prose');
      if (!prose) return;

      const sidenotes = prose.querySelectorAll('.sidenote');
      if (!sidenotes.length) return;

      // Remove any existing footnotes section (View Transitions may re-run this)
      const existing = prose.querySelector('.sidenote-footnotes');
      if (existing) existing.remove();

      const section = document.createElement('section');
      section.className = 'sidenote-footnotes';
      section.setAttribute('role', 'doc-endnotes');
      section.setAttribute('aria-label', 'Footnotes');

      const ol = document.createElement('ol');

      sidenotes.forEach((note) => {
        const id = note.dataset.noteId;
        const li = document.createElement('li');
        li.id = 'note-' + id + '-foot';
        li.innerHTML = note.innerHTML
          + ' <a href="#ref-' + id + '" class="sidenote-backlink" aria-label="Back to text">\u21A9</a>';
        ol.appendChild(li);
      });

      section.appendChild(ol);
      prose.appendChild(section);

      // Point the superscript anchor links to the footnotes
      sidenotes.forEach((note) => {
        const id = note.dataset.noteId;
        const ref = document.getElementById('ref-' + id);
        if (ref) {
          const link = ref.querySelector('a');
          if (link) link.href = '#note-' + id + '-foot';
        }
      });
    });
  </script>
</Base>
