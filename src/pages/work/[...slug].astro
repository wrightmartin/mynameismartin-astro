---
/*
  Individual Case Study Page
  --------------------------
  Dynamic route that renders a single portfolio project.
  Displays category label, title, subtitle, a metadata block
  (role, client, date, visit link), the markdown body, and
  prev/next navigation to adjacent case studies.
*/

import Page from '../../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('work');

  /* Sort by order so prev/next links follow the intended sequence */
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.data.slug },
    props: {
      project,
      prevProject: index > 0 ? sorted[index - 1] : null,
      nextProject: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;
const { Content } = await render(project);

/* The date field is a plain string like "2024-2025" or "2024" */
---

<Page title={`${project.data.title} — Martin Wright`}>

  <article class="case-study">

    <!-- Case study header: category, title, subtitle -->
    <header class="case-study-header page-section">
      <p class="case-study-category">{project.data.category}</p>
      <h1>{project.data.title}</h1>
      <p class="case-study-subtitle">{project.data.subtitle}</p>
    </header>

    <!-- Metadata block: role, client, date, visit link -->
    <aside class="case-study-meta page-section">
      <div class="case-study-meta-grid">

        {project.data.role && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Role</span>
            <span class="case-study-meta-value">{project.data.role}</span>
          </div>
        )}

        {project.data.client && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Client</span>
            <span class="case-study-meta-value">{project.data.client}</span>
          </div>
        )}

        {project.data.date && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Date</span>
            <span class="case-study-meta-value">{project.data.date}</span>
          </div>
        )}

        {project.data.url && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Visit</span>
            <span class="case-study-meta-value">
              <a href={project.data.url} target="_blank" rel="noopener noreferrer">
                {project.data.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </span>
          </div>
        )}

      </div>
    </aside>

    <!-- Markdown body content -->
    <div class="case-study-body page-section">
      <div class="prose">
        <Content />
      </div>
    </div>

  </article>

  <!-- Previous / Next case study navigation -->
  {(prevProject || nextProject) && (
    <nav class="case-study-nav page-section" aria-label="More case studies">

      {prevProject ? (
        <a href={`/work/${prevProject.data.slug}`} class="case-study-nav-link case-study-nav-prev">
          <span class="case-study-nav-direction">Previous project</span>
          <span class="case-study-nav-title">{prevProject.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}

      {nextProject ? (
        <a href={`/work/${nextProject.data.slug}`} class="case-study-nav-link case-study-nav-next">
          <span class="case-study-nav-direction">Next project</span>
          <span class="case-study-nav-title">{nextProject.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}

    </nav>
  )}

</Page>

<style>
  /* ==========================================================================
     Case Study Page
     Styles specific to the individual work/case study layout.
     ========================================================================== */


  /* --- Header ---
     Category label above the title, subtitle below it.
     ---------------------------------------------------------------------- */

  .case-study-header {
    padding-bottom: var(--space-lg);
  }

  .case-study-category {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--colour-text-light);
    margin-bottom: var(--space-sm);
  }

  .case-study-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--colour-text-light);
    max-width: 55ch;
    margin-top: var(--space-sm);
  }


  /* --- Metadata Block ---
     A clean horizontal grid of role, client, date, and visit link.
     Each item has a small uppercase label above the value.
     On mobile the items stack into two columns.
     ---------------------------------------------------------------------- */

  .case-study-meta {
    padding-block: var(--space-lg);
    border-top: 1px solid var(--colour-border);
    border-bottom: 1px solid var(--colour-border);
  }

  .case-study-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg) var(--space-xl);
  }

  @media (min-width: 768px) {
    .case-study-meta-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .case-study-meta-label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--colour-text-light);
    margin-bottom: var(--space-2xs);
  }

  .case-study-meta-value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-body);
    color: var(--colour-text);
  }

  .case-study-meta-value a {
    color: var(--colour-text);
  }


  /* --- Body ---
     The markdown content area. Constrained to content-width for readability.
     The .prose class in layout.css handles spacing between elements.
     ---------------------------------------------------------------------- */

  .case-study-body {
    border-top: none;
  }

  .case-study-body .prose {
    max-width: var(--content-width);
  }


  /* --- Prev / Next Navigation ---
     Two-column layout with previous on the left, next on the right.
     Each link shows a small directional label and the project title.
     ---------------------------------------------------------------------- */

  .case-study-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    border-top: 1px solid var(--colour-border);
  }

  .case-study-nav-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: var(--space-md) 0;
    transition: color 0.2s ease;
  }

  .case-study-nav-link:hover {
    color: var(--colour-text-light);
  }

  .case-study-nav-next {
    text-align: right;
  }

  .case-study-nav-direction {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--colour-text-light);
    margin-bottom: var(--space-2xs);
  }

  .case-study-nav-title {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: 700;
    line-height: 1.3;
  }
</style>
