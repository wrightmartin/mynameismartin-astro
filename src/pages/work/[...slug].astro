---
/*
  Individual Case Study Page
  --------------------------
  Dynamic route that renders a single portfolio project.
  Displays category label, title, subtitle, a metadata block
  (role, client, date, visit link), the markdown body, and
  prev/next navigation to adjacent case studies.
*/

import Page from '../../layouts/Page.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('work');

  /* Sort by order so prev/next links follow the intended sequence */
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, index) => ({
    params: { slug: project.data.slug },
    props: {
      project,
      prevProject: index > 0 ? sorted[index - 1] : null,
      nextProject: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { project, prevProject, nextProject } = Astro.props;
const { Content } = await render(project);

/* The date field is a plain string like "2024-2025" or "2024" */
---

<Page
  title={project.data.title}
  description={project.data.subtitle}
  ogType="article"
  ogImage={project.data.thumbnail}
>

  <article class="case-study">

    <!-- Case study header: category, title, subtitle -->
    <header class="case-study-header page-section">
      <p class="case-study-category">{project.data.category}</p>
      <h1>{project.data.title}</h1>
      <p class="case-study-subtitle">{project.data.subtitle}</p>
    </header>

    <!-- Metadata block: role, client, date, visit link -->
    <aside class="case-study-meta page-section">
      <div class="case-study-meta-grid">

        {project.data.role && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Role</span>
            <span class="case-study-meta-value">{project.data.role}</span>
          </div>
        )}

        {project.data.client && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Client</span>
            <span class="case-study-meta-value">{project.data.client}</span>
          </div>
        )}

        {project.data.date && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Date</span>
            <span class="case-study-meta-value">{project.data.date}</span>
          </div>
        )}

        {project.data.url && (
          <div class="case-study-meta-item">
            <span class="case-study-meta-label">Visit</span>
            <span class="case-study-meta-value">
              <a href={project.data.url} target="_blank" rel="noopener noreferrer">
                {project.data.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
              </a>
            </span>
          </div>
        )}

      </div>
    </aside>

    <!-- Markdown body content -->
    <div class="case-study-body page-section">
      <Content />
    </div>

  </article>

  <!-- Previous / Next case study navigation -->
  {(prevProject || nextProject) && (
    <nav class="case-study-nav page-section" aria-label="More case studies">

      {prevProject ? (
        <a href={`/work/${prevProject.data.slug}`} class="case-study-nav-link case-study-nav-prev">
          <span class="case-study-nav-direction">Previous project</span>
          <span class="case-study-nav-title">{prevProject.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}

      {nextProject ? (
        <a href={`/work/${nextProject.data.slug}`} class="case-study-nav-link case-study-nav-next">
          <span class="case-study-nav-direction">Next project</span>
          <span class="case-study-nav-title">{nextProject.data.title}</span>
        </a>
      ) : (
        <span></span>
      )}

    </nav>
  )}

</Page>
