---
/*
  Get in Touch Page
  -----------------
  Contact form (Netlify Forms) with social media links.
*/

import Page from '../layouts/Page.astro';
---

<Page title="Contact me" description="Get in touch to discuss working together.">

  <section class="page-section contact-hero">
    <h1>Contact me</h1>
    <p class="contact-intro">Send me a message using the form below, or find me on social media.</p>
  </section>

  <!-- Contact form -->
  <section class="page-section contact-form-section pt-0 pb-0">
    <form
      class="contact-form"
      name="contact"
      method="POST"
      action="/success"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="visually-hidden">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="form-field">
        <label for="name" class="form-label">Name</label>
        <input type="text" id="name" name="name" required class="form-input" />
      </div>

      <div class="form-field">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" required class="form-input" />
      </div>

      <div class="form-field">
        <label for="message" class="form-label">Message</label>
        <textarea id="message" name="message" rows="6" required class="form-input form-textarea"></textarea>
      </div>

      <button type="submit" class="form-submit">Send message</button>
    </form>
  </section>

  <!-- Social links -->
  <section class="page-section contact-social">
    <h2>Or find me on</h2>
    <ul class="contact-social-list">
      <li>
        <a href="https://www.linkedin.com/in/martinjwright/" target="_blank" rel="noopener noreferrer">
          LinkedIn
        </a>
      </li>
      <li>
        <a href="https://bsky.app/profile/mynameismartin.co.uk" target="_blank" rel="noopener noreferrer">
          Bluesky
        </a>
      </li>
    </ul>
  </section>

</Page>
